# Hosted agent-brain — Cursor plugin (client only)
# Copy values to your environment; do not commit secrets.

NIGHTHAWK_MCP_URL=https://memory.example.com/sse

# Auth: use ONE of the following
NIGHTHAWK_API_KEY=
# NIGHTHAWK_JWT=

# Agent scope (user-defined install)
# Global:    cursor-<user>
# Project:   cursor-<user>-<project>
NIGHTHAWK_AGENT_ID=cursor-you

# Optional: hooks may override per Composer thread
# NIGHTHAWK_SESSION_ID=
