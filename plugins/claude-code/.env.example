# Hosted agent-brain — Claude Code plugin (client only)

NIGHTHAWK_MCP_URL=https://memory.example.com/sse

# Auth: use ONE of the following
NIGHTHAWK_API_KEY=
# NIGHTHAWK_JWT=

# Agent scope (user-defined)
# User-global install:  claude-<user>
# Project-scoped:       claude-<user>-<project>
NIGHTHAWK_AGENT_ID=claude-you

# Optional: hooks set per session from SessionStart (session_id)
# NIGHTHAWK_SESSION_ID=
